<Window x:Class="KameraSteuerungDeLuxe.SettingsWindow"
        xmlns:local="clr-namespace:KameraSteuerungDeLuxe"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        Title="Einstellungen" Height="710" Width="370"
        Background="#1e1e1e"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=local:SettingsWindowViewModel}">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style TargetType="ComboBox" x:Key="PresetCombo">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#333333" />
            <Setter Property="BorderBrush" Value="#555555" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="4" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Name="ToggleButton"
                                  Background="{TemplateBinding Background}"
                                  Foreground="{TemplateBinding Foreground}"
                                  BorderBrush="{TemplateBinding BorderBrush}"
                                  BorderThickness="{TemplateBinding BorderThickness}"
                                  Focusable="false"
                                  ClickMode="Press"
                                  IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ContentPresenter Margin="4,0,0,0"
                                          VerticalAlignment="Center"
                                          HorizontalAlignment="Left"
                                          Content="{TemplateBinding SelectionBoxItem}"
                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                          ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}" />
                            </ToggleButton>
                            <Popup Name="Popup"
                           Placement="Bottom"
                           IsOpen="{TemplateBinding IsDropDownOpen}"
                           AllowsTransparency="True"
                           Focusable="False"
                           PopupAnimation="Slide">
                                <Grid MaxHeight="300" Width="100"
                              Background="#222222"
                              SnapsToDevicePixels="True">
                                    <Border BorderThickness="1" BorderBrush="#555555" Background="#222222" />
                                    <ScrollViewer Margin="4" SnapsToDevicePixels="True">
                                        <ItemsPresenter />
                                    </ScrollViewer>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ComboBox" x:Key="DefaultCombo">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#333333" />
            <Setter Property="BorderBrush" Value="#555555" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="4" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Name="ToggleButton"
                                  Background="{TemplateBinding Background}"
                                  Foreground="{TemplateBinding Foreground}"
                                  BorderBrush="{TemplateBinding BorderBrush}"
                                  BorderThickness="{TemplateBinding BorderThickness}"
                                  Focusable="false"
                                  ClickMode="Press"
                                  IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ContentPresenter Margin="4,0,0,0"
                                          VerticalAlignment="Center"
                                          HorizontalAlignment="Left"
                                          Content="{TemplateBinding SelectionBoxItem}"
                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                          ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}" />
                            </ToggleButton>
                            <Popup Name="Popup"
                           Placement="Bottom"
                           IsOpen="{TemplateBinding IsDropDownOpen}"
                           AllowsTransparency="True"
                           Focusable="False"
                           PopupAnimation="Slide">
                                <Grid MaxHeight="300" 
                              Background="#222222"
                              SnapsToDevicePixels="True">
                                    <Border BorderThickness="1" BorderBrush="#555555" Background="#222222" />
                                    <ScrollViewer Margin="4" SnapsToDevicePixels="True">
                                        <ItemsPresenter />
                                    </ScrollViewer>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="160" />
            <ColumnDefinition Width="170" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="30" />
            <RowDefinition Height="30" />
            <RowDefinition Height="30" />
            <RowDefinition Height="30" />
            <RowDefinition Height="30" />
            <RowDefinition Height="30" />
            <RowDefinition Height="30" />
            <RowDefinition Height="1*" />
            <RowDefinition Height="40" />
        </Grid.RowDefinitions>
        <TextBlock Grid.Column="0" Text="Kamera IP &amp; Port:" />
        <StackPanel Grid.Row="0" Grid.Column="1"
                    Orientation="Horizontal">
            <TextBox Grid.Column="1"
                 x:Name="IpBox"
                 Text="{Binding CameraIp, Mode=TwoWay}"
                 Background="#2e2e2e"
                 Foreground="White"
                 FontSize="13"
                 Width="100"
                 VerticalContentAlignment="Center" />
            <TextBlock Text=":" Margin="2,0" />
            <TextBox Width="63"
                        HorizontalAlignment="Left"
                        x:Name="PortBox"
                        Text="{Binding CameraPort, Mode=TwoWay}"
                        Background="#2e2e2e"
                        Foreground="White"
                        FontSize="13" VerticalContentAlignment="Center" />
        </StackPanel>
        <Button Click="SearchCamera_Click" Grid.Row="1" Content="Kamera suchen" Margin="10,5" Visibility="{Binding SearchIsIdle, Converter={StaticResource BoolToVisibilityConverter}}" />
        <ProgressBar Grid.Row="1" IsIndeterminate="True" Margin="10,5" Visibility="{Binding SearchIsWorking, Converter={StaticResource BoolToVisibilityConverter}}" />
        <ComboBox Grid.Row="1" Grid.Column="1"
                  Style="{StaticResource DefaultCombo}"
                  ItemsSource="{Binding AvailableCameras}"
                  Visibility="{Binding AvailableCamerasAny, Converter={StaticResource BoolToVisibilityConverter}}"
                  SelectedItem="{Binding SelectedCamera}"
                  HorizontalContentAlignment="Stretch"
                  MinWidth="150">
        </ComboBox>
        <TextBlock Grid.Column="0" Grid.Row="2" Text="Presets für Power On | Off:" />
        <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal">
            <ComboBox Width="80" 
                      Style="{StaticResource PresetCombo}"
                      Text="{Binding PresetCameraOn}">
                <ComboBoxItem Content="1" />
                <ComboBoxItem Content="2" />
                <ComboBoxItem Content="3" />
                <ComboBoxItem Content="4" />
                <ComboBoxItem Content="5" />
                <ComboBoxItem Content="6" />
                <ComboBoxItem Content="7" />
                <ComboBoxItem Content="8" />
                <ComboBoxItem Content="9" />
                <ComboBoxItem Content="0" />
                <ComboBoxItem Content="Deaktiviert" />
            </ComboBox>
            <ComboBox Text="{Binding PresetCameraOff, Mode=TwoWay}" 
                      Style="{StaticResource PresetCombo}"
                      Width="80" Margin="10,0,0,0">
                <ComboBoxItem Content="1" />
                <ComboBoxItem Content="2" />
                <ComboBoxItem Content="3" />
                <ComboBoxItem Content="4" />
                <ComboBoxItem Content="5" />
                <ComboBoxItem Content="6" />
                <ComboBoxItem Content="7" />
                <ComboBoxItem Content="8" />
                <ComboBoxItem Content="9" />
                <ComboBoxItem Content="0" />
                <ComboBoxItem Content="Deaktiviert" />
            </ComboBox>
        </StackPanel>
        <CheckBox Grid.Row="3" IsChecked="{Binding OpenOnStart, Mode=TwoWay}"
                  Content="Beim Start ausführen"
                  Foreground="White"
                  Grid.ColumnSpan="2"
                  VerticalContentAlignment="Center" />
        <CheckBox Grid.Row="4" IsChecked="{Binding ShowWindowOnStartup, Mode=TwoWay}"
          Content="Fenster beim Starten anzeigen"
          Foreground="White"
          Grid.ColumnSpan="2"
          VerticalContentAlignment="Center" />
        <CheckBox Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2"
                  IsChecked="{Binding HideWindowOnClick, Mode=TwoWay}"
          Content="Fenster Ausblenden nach Click"
          Foreground="White"
          VerticalContentAlignment="Center" />
        <CheckBox Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2"
                  IsChecked="{Binding ShowManualControlWindow, Mode=TwoWay}"
                  Content="Manuelle Steuerung ermöglichen"
                  VerticalContentAlignment="Center"
                  Foreground="White" />
        <ItemsControl Grid.Column="0" Grid.ColumnSpan="3" Grid.Row="7"
            ItemsSource="{Binding Buttons}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Grid Width="80" Height="133" Margin="1,1,1,10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="74" />
                            <RowDefinition Height="60" />
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0" Background="#226084">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="50" />
                                <RowDefinition Height="24" />
                            </Grid.RowDefinitions>
                            <Image    Grid.Row="0"
                                      Source="{Binding IconUrl}"
                                      HorizontalAlignment="Center" />
                            <TextBox  Grid.Row="1"
                                      Text="{Binding Name, Mode=TwoWay}"
                                      Background="#226084"
                                      TextAlignment="Center"
                                      FontSize="18"
                                      Foreground="White" />
                        </Grid>
                        <Grid Grid.Row="1" Background="#143a51">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="20" />
                                <RowDefinition Height="20" />
                                <RowDefinition Height="20" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0"
                                      Text="Icon:"
                                      Margin="3"
                                      Foreground="White"
                                      HorizontalAlignment="Left" />
                            <ComboBox Grid.Row="0"
                                      Style="{StaticResource DefaultCombo}"
                                      ItemsSource="{Binding DataContext.AvailableIcons, RelativeSource={RelativeSource AncestorType=Window}}"
                                      SelectedItem="{Binding Icon, Mode=TwoWay}"
                                      Width="46"
                                      Margin="0"
                                      Background="#102f41"
                                      HorizontalAlignment="Right" />
                            <TextBlock Grid.Row="1"
                                      Text="Taste:"
                                      Margin="2"
                                      Foreground="White"
                                      HorizontalAlignment="Left" />
                            <ComboBox Grid.Row="1"
                                      Style="{StaticResource PresetCombo}"
                                      ItemsSource="{Binding DataContext.AvailablePresets, RelativeSource={RelativeSource AncestorType=Window}}"
                                      SelectedItem="{Binding Preset, Mode=TwoWay}"
                                      Width="46"
                                      Background="#102f41"
                                      Margin="0,-2"

                                      HorizontalAlignment="Right" />
                            <CheckBox Grid.Row="2"
                                      Margin="2,0"
                                      Content="Anzeigen"
                                      IsChecked="{Binding Aktiviert, Mode=TwoWay}"
                                      Foreground="White" />
                        </Grid>
                    </Grid>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
        <Button Grid.Row="8" Grid.Column="0"
                Content="Abbrechen"
                Click="Cancel_Click" Margin="0,0,0,0" />
        <Button Grid.Row="8" Grid.Column="1"
        Content="Speichern"
        Click="Save_Click" Margin="0,0,0,0" />
    </Grid>
</Window>