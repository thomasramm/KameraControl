<Window x:Class="KameraSteuerungDeLuxe.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:KameraSteuerungDeLuxe"
        xmlns:core="clr-namespace:KameraSteuerungDeLuxe.Core"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=local:MainViewModel}"
        Title="Kamera Steuerung"
        SizeToContent="WidthAndHeight"
        MinHeight="100"
        WindowStyle="None"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Background="#1e1e1e"
        MouseDown="Window_MouseDown"
        Closing="Window_Closing">
    <Window.Resources>
        <core:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" FalseVisibility="Collapsed" />
        <core:BoolToVisibilityConverter x:Key="BoolToHeightConverter" />
    </Window.Resources>
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <!-- Konfigurierbare Button -->
        <ItemsControl Grid.Column="0"
                      ItemsSource="{Binding Buttons}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Button Width="80" Visibility="{Binding Aktiviert, Converter={StaticResource BoolToVisibilityConverter}}"
                            Margin="1"
                            Background="{Binding Background, Mode=OneWay}"
                            Command="{Binding DataContext.ButtonClickCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                            CommandParameter="{Binding}">
                        <StackPanel>
                            <Image Source="{Binding IconUrl}" Width="80" Height="50" HorizontalAlignment="Center" />
                            <TextBlock Text="{Binding Name}"
                                       TextAlignment="Center"
                                       core:TextBlockExtensions.AutoShrinkFont="True"
                                       core:TextBlockExtensions.MaxFontSize="18"
                                       core:TextBlockExtensions.MinFontSize="9"
                                       Height="20"
                                       Padding="0"
                                       Foreground="White"
                                       Width="80" />
                        </StackPanel>
                    </Button>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
        <!-- Power und Manueller Zoom/Pan -->
        <StackPanel Grid.Column="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center">
            <Button Width="80" Height="80"
                    Margin="1"
                    Background="#226084"
                    Command="{Binding ButtonManualMoveCommand}"
                    Visibility="{Binding ManualControlButtonIsEnabled, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel Orientation="Vertical" Margin="0,0,0,0">
                    <Image Source="/images/manuell.png" Height="38" Margin="8" />
                    <TextBlock Text="Manuell" Foreground="White" FontSize="15" HorizontalAlignment="Center" />
                </StackPanel>
            </Button>
            <Button Width="80" Height="80"
                    Margin="1"
                    Background="#226084"
                    Command="{Binding ButtonPowerOnCommand}">
                <StackPanel Orientation="Vertical" Margin="0,0,0,0">
                    <Image Source="/images/power_on.png" Height="50" />
                    <TextBlock Text="An" Foreground="White" FontSize="20" HorizontalAlignment="Center" />
                </StackPanel>
            </Button>
            <Button Width="80" Height="80"
                Background="#226084"
                Margin="2,0"
                Command="{Binding ButtonPowerOffCommand}">
                <StackPanel Orientation="Vertical" Margin="0,0,0,0">
                    <Image Source="/images/power_off.png" Height="50" />
                    <TextBlock Text="Aus" Foreground="White" FontSize="20" VerticalAlignment="Center" HorizontalAlignment="Center" />
                </StackPanel>
            </Button>
        </StackPanel>
    </Grid>
</Window>